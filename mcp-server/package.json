{
  "name": "godotforge-mcp",
  "version": "0.1.0",
  "description": "GodotForge MCP Server — AI Copilot for Godot Engine",
  "type": "module",
  "bin": {
    "godotforge-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/web dist/web",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.8.0",
    "fast-xml-parser": "^5.5.9",
    "jsfxr": "^1.4.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/**/*"
  ],
  "keywords": [
    "godot",
    "mcp",
    "ai",
    "copilot",
    "claude",
    "game-development"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/godotforge/godotforge"
  },
  "license": "MIT"
}
